@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<div class="auth-status">
    <AuthorizeView>
        <Authorized>
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <i class="bi bi-person-circle me-2"></i>
                    <span>Welcome, @context.User.Identity?.Name</span>
                </div>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <i class="bi bi-person-x me-2"></i>
                    <span class="text-muted">Not signed in</span>
                </div>
                <button class="btn btn-sm btn-outline-primary" @onclick="TrySignIn">
                    <i class="bi bi-box-arrow-in-right me-1"></i>
                    Sign In
                </button>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private void TrySignIn()
    {
        // Navigate to trigger authentication
        Navigation.NavigateTo("authentication/login", forceLoad: true);
    }
}

