@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<div class="auth-error-container">
    <div class="alert alert-info" role="alert">
        <h4 class="alert-heading">
            <i class="bi bi-info-circle me-2"></i>
            Authentication Service Unavailable
        </h4>
        <p>The authentication service is currently unavailable. This is completely optional - you can continue using the application without signing in.</p>
        <p>The app will work normally with full functionality available to anonymous users.</p>
        <hr>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" @onclick="TryAgain">
                <i class="bi bi-arrow-clockwise me-1"></i>
                Try Again
            </button>
        </div>
    </div>

    <div class="mt-3">
        <details class="small">
            <summary>Troubleshooting Information</summary>
            <div class="mt-2 p-2 bg-light rounded">
                <p><strong>Application Status:</strong> Running normally</p>
                <p><strong>API Endpoint:</strong> @GetApiEndpoint()</p>
                <p><strong>Authentication:</strong> Optional - app works without it</p>
                <p><strong>Note:</strong> You can sign in later when the authentication service is available</p>
            </div>
        </details>
    </div>
</div>

@code {
    private void TryAgain()
    {
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }

    private string GetApiEndpoint()
    {
        // Try to get the API endpoint from configuration or default
        return "http://localhost:5196";
    }
}

